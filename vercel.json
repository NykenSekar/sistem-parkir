{
  "version": 2,
  "cleanUrls": true,
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "server.js",
      "routePrefix": "/api"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/|assets/|.*\\.).*)",
      "destination": "/"
    }
  ]
}
